# ConstructPC Bot - environment variables
# Copy this file to .env and fill values.

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
MINIAPP_URL=https://your-miniapp-domain.example
# Legacy bot allow-list. Mini App ignores this if OWNER/OPERATOR roles are set.
ALLOWED_USER_IDS=123456789
# Mini App role model:
OWNER_USER_IDS=123456789
OPERATOR_USER_IDS=

# Storage paths
DOCUMENTS_PATH=./data/documents
DATABASE_PATH=./data/bot.db

# AI parser (OpenAI-compatible endpoint)
AI_API_KEY=your_api_key_here
# Legacy alias, optional:
GEMINI_API_KEY=
AI_BASE_URL=https://api.ohmylama.com/v1
AI_MODEL=gpt-5.4-mini

# Google Sheets export (optional)
GOOGLE_CREDS_PATH=./data/credentials.json
SPREADSHEET_ID=
SPREADSHEET_TITLE=ConstructPC Управленческий учет
SPREADSHEET_SHARE_EMAIL=

# Mini App API (Day 1 bootstrap)
MINIAPP_DATABASE_URL=postgresql+asyncpg://construct:construct_local_password@127.0.0.1:5432/construct_miniapp
MINIAPP_DOCUMENTS_DIR=./data/miniapp_documents
MINIAPP_MAX_UPLOAD_MB=50
MINIAPP_REPORT_DEFAULT_DAYS=7
MINIAPP_SOFT_LAUNCH_OWNER_ONLY=1
MINIAPP_SOFT_LAUNCH_OPERATOR_USER_IDS=
MINIAPP_NOTIFICATION_MODE=critical_only
MINIAPP_RATE_LIMIT_ENABLED=1
MINIAPP_RATE_LIMIT_WINDOW_SECONDS=60
MINIAPP_RATE_LIMIT_GENERAL_PER_WINDOW=240
MINIAPP_RATE_LIMIT_WRITE_PER_WINDOW=120
MINIAPP_RATE_LIMIT_AUTH_PER_WINDOW=30
MINIAPP_CORS_ORIGINS=https://your-miniapp-domain.example,http://127.0.0.1:8081
API_BASE_PATH=/api/v1
JWT_SECRET=replace_with_64_plus_random_chars
JWT_TTL_SECONDS=28800
MINIAPP_API_HOST=0.0.0.0
MINIAPP_API_PORT=8080
