prefix=/opt/pginstaller_15.auto/server/staging_cache/osx.build
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: libecpg
Description: PostgreSQL libecpg library
Url: https://www.postgresql.org/
Version: 15.12
Requires: 
Requires.private: libpq libpgtypes
Cflags: -I${includedir}
Libs: -L${libdir} -lecpg
Libs.private: -L/opt/local/20240903/lib -L/opt/local/Current_v15/lib -lpgcommon -lpgport -lm
