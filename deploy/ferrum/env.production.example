# Ferrum production environment example
# Copy to /srv/construct/app/.env on the server and fill real secrets.

APP_ENV=production

# Telegram
TELEGRAM_BOT_TOKEN=replace_with_real_bot_token
MINIAPP_URL=https://constructpc.aleksandrantropov.ru
TELEGRAM_TRUST_ENV=auto

# Roles
ALLOWED_USER_IDS=
OWNER_USER_IDS=661916730,962441603,932026723
OPERATOR_USER_IDS=

# Legacy bot
DOCUMENTS_PATH=./data/documents
DATABASE_PATH=./data/bot.db
DATA_WIPE_TRIGGER_CODE=1100
DATA_WIPE_PIN=0011

# AI
AI_API_KEY=replace_with_real_ai_api_key
AI_BASE_URL=https://ohmylama.ru/v1
AI_MODEL=gpt-5.4-mini
AI_MODEL_OPTIONS=gpt-5.4-mini,gpt-5.4,gpt-5-mini,claude-sonnet-4.6,gemini-2.5-flash

# Google Sheets
GOOGLE_CREDS_PATH=./data/credentials.json
SPREADSHEET_ID=
SPREADSHEET_TITLE=ConstructPC Управленческий учет
SPREADSHEET_SHARE_EMAIL=

# Mini App API
MINIAPP_DATABASE_URL=postgresql+asyncpg://construct:replace_with_db_password@127.0.0.1:5432/construct_miniapp
MINIAPP_DOCUMENTS_DIR=./data/miniapp_documents
MINIAPP_MAX_UPLOAD_MB=50
MINIAPP_REPORT_DEFAULT_DAYS=7
MINIAPP_SOFT_LAUNCH_OWNER_ONLY=0
MINIAPP_SOFT_LAUNCH_OPERATOR_USER_IDS=
MINIAPP_NOTIFICATION_MODE=critical_only
MINIAPP_RATE_LIMIT_ENABLED=1
MINIAPP_RATE_LIMIT_WINDOW_SECONDS=60
MINIAPP_RATE_LIMIT_GENERAL_PER_WINDOW=240
MINIAPP_RATE_LIMIT_WRITE_PER_WINDOW=120
MINIAPP_RATE_LIMIT_AUTH_PER_WINDOW=30
MINIAPP_CORS_ORIGINS=https://constructpc.aleksandrantropov.ru,https://app.pckonstruct.com
API_BASE_PATH=/api/v1
JWT_SECRET=replace_with_64_plus_random_chars
JWT_TTL_SECONDS=28800
MINIAPP_API_HOST=127.0.0.1
MINIAPP_API_PORT=8080
